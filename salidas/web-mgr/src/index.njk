            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <div>
          <h3 class="font-semibold text-sm mb-1 text-[#1a0a0e]">Gestión profesional</h3>
          <p class="text-muted text-sm leading-relaxed">Organizamos cada etapa del proceso. Nada queda librado al azar.</p>
        </div>
      </div>

      <div class="p-7 bg-light rounded-2xl flex gap-5 items-start">
        <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center rounded-full bg-white shadow-sm">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <h3 class="font-semibold text-sm mb-1 text-[#1a0a0e]">Conexión interior–CABA</h3>
          <p class="text-muted text-sm leading-relaxed">Trabajamos con compradores del interior que buscan propiedades en Capital. Un canal de demanda que muchas inmobiliarias no aprovechan.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- FORMULARIO DE TASACIÓN -->
<section id="tasacion">
  <div class="bg-dark text-white py-14 md:py-16 text-center px-4">
    <h2 class="text-3xl md:text-4xl font-bold mb-3">Solicitá una tasación profesional</h2>
    <p class="text-white/60 text-base max-w-md mx-auto">Completá el formulario y te contactamos para coordinar la evaluación de tu propiedad.</p>
  </div>
  <div class="bg-light py-12 md:py-16 px-4">
    <div class="max-w-lg mx-auto">
      <form id="tasacion-form" class="space-y-4 bg-white p-8 rounded-2xl shadow-sm">

        <div>
          <label class="block text-xs font-semibold text-[#1a0a0e] uppercase tracking-wide mb-1.5">Nombre completo</label>
          <input type="text" name="nombre" required placeholder="Tu nombre y apellido"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#c93d65] focus:border-transparent bg-white transition-all">
        </div>

        <div>
          <label class="block text-xs font-semibold text-[#1a0a0e] uppercase tracking-wide mb-1.5">Teléfono / WhatsApp</label>
          <input type="tel" name="telefono" required placeholder="11 1234-5678"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#c93d65] focus:border-transparent bg-white transition-all">
        </div>

        <div>
          <label class="block text-xs font-semibold text-[#1a0a0e] uppercase tracking-wide mb-1.5">Tipo de propiedad</label>
          <select name="tipo" required
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#c93d65] focus:border-transparent bg-white transition-all text-[#1a0a0e]">
            <option value="" disabled selected>Seleccioná una opción</option>
            <option>Departamento</option>
            <option>Casa</option>
            <option>PH</option>
            <option>Local comercial</option>
            <option>Otro</option>
          </select>
        </div>

        <div>
          <label class="block text-xs font-semibold text-[#1a0a0e] uppercase tracking-wide mb-1.5">Barrio o zona</label>
          <input type="text" name="barrio" required placeholder="Ej: Palermo, Belgrano, Villa Urquiza"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#c93d65] focus:border-transparent bg-white transition-all">
        </div>

        <div>
          <label class="block text-xs font-semibold text-[#1a0a0e] uppercase tracking-wide mb-1.5">
            Superficie aproximada
            <span class="normal-case font-normal text-muted ml-1">(opcional)</span>
          </label>
          <input type="number" name="superficie" placeholder="m²"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#c93d65] focus:border-transparent bg-white transition-all">
        </div>

        <button type="submit"
          class="w-full bg-accent hover:bg-accent-dark text-white font-semibold py-4 px-8 rounded-xl transition-colors duration-200 text-base mt-2">
          Solicitar tasación profesional
        </button>
        <p class="text-center text-muted text-xs pt-1 flex items-center justify-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Te respondemos el mismo día.
        </p>
      </form>
      <p class="text-center text-muted text-sm mt-6">
        ¿Querés saber más antes de decidir?
        <a href="/tasacion-profesional/" class="text-accent font-semibold hover:underline ml-1">Conocé nuestra tasación profesional →</a>
      </p>
    </div>
  </div>
</section>

{% block scripts %}
<script>
  document.getElementById('tasacion-form').addEventListener('submit', function (e) {
    e.preventDefault();
    const n = this.nombre.value.trim();
    const t = this.telefono.value.trim();
    const tipo = this.tipo.value;
    const b = this.barrio.value.trim();
    const s = this.superficie.value.trim();
    let msg = `Hola, quiero solicitar una tasación profesional para mi propiedad.\n\n• Nombre: ${n}\n• Teléfono: ${t}\n• Tipo: ${tipo}\n• Barrio: ${b}`;
    if (s) msg += `\n• Superficie: ${s} m²`;
    window.open(`https://wa.me/{{ site.wa.number }}?text=${encodeURIComponent(msg)}`, '_blank');
  });
</script>
{% endblock %}
