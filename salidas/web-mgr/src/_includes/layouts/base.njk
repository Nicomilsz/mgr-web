<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% if barrio %}
    {% set metaDesc = (tipo or "Propiedad") + " en " + barrio + ", CABA. " + (precio_texto or "Consultá el precio") + ". Contacto directo con MGR Inmobiliaria." %}
  {% else %}
    {% set metaDesc = description or "Inmobiliaria en CABA. Tasación profesional, gestión clara y trato directo." %}
  {% endif %}
  <meta name="description" content="{{ metaDesc }}">
  {% if barrio and fotos and fotos.length > 0 %}
  <meta property="og:image" content="{{ fotos[0] }}">
  {% else %}
  <meta property="og:image" content="/assets/brand/mgr-logo-circular.png">
  {% endif %}
  <meta name="theme-color" content="#2d0a17">
  <link rel="icon" type="image/png" href="/assets/brand/mgr-logo-circular.png">
  <title>{% if title %}{{ title }} | {% endif %}MGR Inmobiliaria</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            dark:          '#2d0a17',
            accent:        '#c93d65',
            'accent-dark': '#a8305a',
            light:         '#faf6f7',
            muted:         '#6b3a45',
          },
          fontFamily: { sans: ['Inter', 'sans-serif'] }
        }
      }
    }
  </script>
  <style>html { scroll-behavior: smooth; }</style>
</head>
<body class="font-sans text-[#1a0a0e] antialiased">

  {% include "navbar.njk" %}

  {{ content | safe }}

  {% if fullFooter %}
    {% include "footer-full.njk" %}
  {% else %}
    {% include "footer-slim.njk" %}
  {% endif %}

  <!-- Botón flotante WhatsApp -->
  <div class="fixed bottom-6 right-6 z-50 group">
    <a href="https://wa.me/{{ site.wa.number }}?text={{ waFloatMsg or site.wa.msgGeneral }}"
       target="_blank"
       class="flex items-center justify-center w-14 h-14 bg-accent hover:bg-accent-dark rounded-full shadow-lg transition-all duration-200 hover:scale-105"
       aria-label="Escribinos por WhatsApp">
      <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
    <span class="absolute right-16 top-1/2 -translate-y-1/2 bg-dark text-white text-xs font-medium px-3 py-1.5 rounded-lg whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none shadow-md">
      Escribinos
    </span>
  </div>

  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar.classList.toggle('shadow-[0_4px_24px_rgba(0,0,0,0.35)]', window.scrollY > 10);
    });
    document.getElementById('menu-toggle').addEventListener('click', () => {
      document.getElementById('mobile-menu').classList.toggle('hidden');
      document.getElementById('icon-menu').classList.toggle('hidden');
      document.getElementById('icon-close').classList.toggle('hidden');
    });
  </script>
  {% block scripts %}{% endblock %}

</body>
</html>
