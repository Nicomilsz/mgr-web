---
layout: base.njk
---

{% set waMsg = mensaje_whatsapp or ("Hola%2C%20consulto%20por%20" + (title | encodeURIComponent) + "%20en%20" + (barrio | encodeURIComponent)) %}

<!-- Aviso demo -->
{% if not publicada %}
<div class="bg-accent/10 border-b border-accent/20 px-4 py-3 text-center">
  <p class="text-xs font-semibold text-accent">⚠ PROPIEDAD DE DEMOSTRACIÓN — Este es un ejemplo de diseño. No publicar como propiedad real.</p>
</div>
{% endif %}

<!-- Volver al catálogo -->
<div class="bg-white border-b border-gray-100 px-4 py-3">
  <div class="max-w-5xl mx-auto">
    <a href="/propiedades/" class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-accent transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Volver al catálogo
    </a>
  </div>
</div>

<!-- GALERÍA -->
<section class="bg-light py-6 px-4">
  <div class="max-w-5xl mx-auto">
    {% if fotos and fotos.length > 0 %}
    <div class="grid grid-cols-4 grid-rows-2 gap-2 h-72 md:h-96 rounded-2xl overflow-hidden">
      <div class="col-span-4 md:col-span-2 row-span-2 relative overflow-hidden">
        <img src="{{ fotos[0] }}" alt="{{ title }}" class="w-full h-full object-cover">
      </div>
      {% if fotos[1] %}
      <div class="hidden md:block col-span-2 relative overflow-hidden">
        <img src="{{ fotos[1] }}" alt="{{ title }}" class="w-full h-full object-cover">
      </div>
      {% else %}
      <div class="hidden md:block col-span-2 bg-gradient-to-br from-[#3d1220] to-dark"></div>
      {% endif %}
      {% if fotos[2] %}
      <div class="hidden md:block col-span-1 relative overflow-hidden">
        <img src="{{ fotos[2] }}" alt="{{ title }}" class="w-full h-full object-cover">
      </div>
      {% else %}
      <div class="hidden md:block col-span-1 bg-gradient-to-br from-dark to-[#5c1f38]/50"></div>
      {% endif %}
      {% if fotos[3] %}
      <div class="hidden md:block col-span-1 relative overflow-hidden">
        <img src="{{ fotos[3] }}" alt="{{ title }}" class="w-full h-full object-cover">
      </div>
      {% else %}
      <div class="hidden md:block col-span-1 bg-gradient-to-br from-[#4a1628] to-accent/20"></div>
      {% endif %}
    </div>
    {% else %}
    <div class="grid grid-cols-4 grid-rows-2 gap-2 h-72 md:h-96 rounded-2xl overflow-hidden">
      <div class="col-span-4 md:col-span-2 row-span-2 bg-gradient-to-br from-dark via-[#4a1628] to-accent/40 flex items-center justify-center">
        <svg class="w-16 h-16 text-white/10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
      <div class="hidden md:block col-span-2 bg-gradient-to-br from-[#3d1220] to-dark"></div>
      <div class="hidden md:block col-span-1 bg-gradient-to-br from-dark to-[#5c1f38]/50"></div>
      <div class="hidden md:block col-span-1 bg-gradient-to-br from-[#4a1628] to-accent/20"></div>
    </div>
    {% endif %}
  </div>
</section>

<!-- CONTENIDO PRINCIPAL -->
<section class="bg-white py-10 md:py-14 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Columna principal -->
      <div class="lg:col-span-2 space-y-10">

        <!-- Encabezado -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-semibold text-accent uppercase tracking-wide">{{ barrio }}</span>
            <span class="text-white/0 select-none">·</span>
            <span class="text-xs text-muted bg-light px-2 py-0.5 rounded-full">{{ tipo }}</span>
            {% if estado and estado != "publicada" %}
            <span class="text-xs bg-dark/10 text-[#1a0a0e] px-2 py-0.5 rounded-full capitalize">{{ estado }}</span>
            {% endif %}
          </div>
          <h1 class="text-2xl md:text-3xl font-bold text-[#1a0a0e] mb-2">{{ title }}</h1>
          <p class="text-muted text-sm">CABA · {{ barrio }}</p>
        </div>

        <!-- Descripción -->
        {% if descripcion %}
        <div>
          <h2 class="text-base font-semibold text-[#1a0a0e] mb-3">Descripción</h2>
          <div class="text-muted text-sm leading-relaxed space-y-3">
            {{ descripcion | safe }}
          </div>
        </div>
        {% endif %}

        <!-- Características -->
        {% if caracteristicas and caracteristicas.length > 0 %}
        <div>
          <h2 class="text-base font-semibold text-[#1a0a0e] mb-4">Características principales</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {% for item in caracteristicas %}
            <div class="flex items-center gap-2 text-sm text-muted bg-light rounded-xl px-4 py-3">
              <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              {{ item }}
            </div>
            {% endfor %}
          </div>
        </div>
        {% endif %}

        <!-- Plano -->
        {% if plano %}
        <div>
          <h2 class="text-base font-semibold text-[#1a0a0e] mb-4">Plano</h2>
          <img src="{{ plano }}" alt="Plano de {{ title }}" class="w-full rounded-2xl border border-gray-100">
        </div>
        {% endif %}

        <!-- Video -->
        {% if video_url %}
        <div>
          <h2 class="text-base font-semibold text-[#1a0a0e] mb-4">Video</h2>
          <div class="aspect-video rounded-2xl overflow-hidden">
            <iframe src="{{ video_url }}" width="100%" height="100%" frameborder="0" allowfullscreen class="w-full h-full"></iframe>
          </div>
        </div>
        {% endif %}

        <!-- Tour virtual -->
        {% if tour_virtual_url %}
        <div>
          <h2 class="text-base font-semibold text-[#1a0a0e] mb-4">Tour virtual</h2>
          <div class="aspect-video rounded-2xl overflow-hidden">
            <iframe src="{{ tour_virtual_url }}" width="100%" height="100%" frameborder="0" allowfullscreen class="w-full h-full"></iframe>
          </div>
        </div>
        {% endif %}

      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-24 bg-light rounded-2xl p-6 space-y-5">

          <div>
            <p class="text-xs text-muted uppercase tracking-wide mb-1">Precio</p>
            <p class="text-2xl font-bold text-[#1a0a0e]">{{ precio_texto or "Consultar" }}</p>
          </div>

          <hr class="border-gray-200">

          <div class="space-y-3 text-sm">
            {% if tipo %}
            <div class="flex justify-between">
              <span class="text-muted">Tipo</span>
              <span class="font-medium text-[#1a0a0e]">{{ tipo }}</span>
            </div>
            {% endif %}
            {% if barrio %}
            <div class="flex justify-between">
              <span class="text-muted">Barrio</span>
              <span class="font-medium text-[#1a0a0e]">{{ barrio }}</span>
            </div>
            {% endif %}
            {% if ambientes %}
            <div class="flex justify-between">
              <span class="text-muted">Ambientes</span>
              <span class="font-medium text-[#1a0a0e]">{{ ambientes }}</span>
            </div>
            {% endif %}
            {% if dormitorios %}
            <div class="flex justify-between">
              <span class="text-muted">Dormitorios</span>
              <span class="font-medium text-[#1a0a0e]">{{ dormitorios }}</span>
            </div>
            {% endif %}
            {% if banos %}
            <div class="flex justify-between">
              <span class="text-muted">Baños</span>
              <span class="font-medium text-[#1a0a0e]">{{ banos }}</span>
            </div>
            {% endif %}
            {% if superficie_total %}
            <div class="flex justify-between">
              <span class="text-muted">Sup. total</span>
              <span class="font-medium text-[#1a0a0e]">{{ superficie_total }} m²</span>
            </div>
            {% endif %}
            {% if superficie_cubierta %}
            <div class="flex justify-between">
              <span class="text-muted">Sup. cubierta</span>
              <span class="font-medium text-[#1a0a0e]">{{ superficie_cubierta }} m²</span>
            </div>
            {% endif %}
            {% if expensas %}
            <div class="flex justify-between">
              <span class="text-muted">Expensas</span>
              <span class="font-medium text-[#1a0a0e]">{{ expensas }}</span>
            </div>
            {% endif %}
            {% if direccion_aproximada %}
            <div class="flex justify-between">
              <span class="text-muted">Zona</span>
              <span class="font-medium text-[#1a0a0e] text-right max-w-[160px]">{{ direccion_aproximada }}</span>
            </div>
            {% endif %}
          </div>

          <hr class="border-gray-200">

          <a href="https://wa.me/{{ site.wa.number }}?text={{ waMsg }}"
             target="_blank"
             class="flex items-center justify-center gap-2 w-full bg-accent hover:bg-accent-dark text-white font-semibold py-4 rounded-xl transition-colors duration-200 text-sm">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Consultar por WhatsApp
          </a>
          <p class="text-center text-muted text-xs">Respondemos el mismo día.</p>

        </div>
      </div>
    </div>
  </div>
</section>
